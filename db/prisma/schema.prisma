generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         Int       @id @default(autoincrement())
  username   String
  password   String
  email      String    @unique
  role       String
  created_at DateTime  @default(now())
  updated_at DateTime?

  invoices      Invoice[]     @relation("CreatedInvoices")
  userCompanies UserCompany[]
}

model Company {
  id        Int     @id @default(autoincrement())
  name      String
  kvkNumber String?
  btwNumber String?
  address   String
  postcode  String
  city      String
  country   String
  iban      String?
  phone     String?
  email     String?
  website   String?
  logo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     UserCompany[]
  invoices  Invoice[]
  relations Relation[]
}

model UserCompany {
  id        Int @id @default(autoincrement())
  userId    Int
  companyId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model Invoice {
  id            Int    @id @default(autoincrement())
  invoiceNumber String @unique

  companyId   Int
  relationId  Int
  createdById Int

  title String

  invoiceDate DateTime
  dueDate     DateTime
  paymentTerm Int

  subTotal Decimal
  vatTotal Decimal
  total    Decimal

  status InvoiceStatus @default(DRAFT)

  company   Company  @relation(fields: [companyId], references: [id])
  createdBy User     @relation("CreatedInvoices", fields: [createdById], references: [id])
  relation  Relation @relation(fields: [relationId], references: [id])

  invoiceLines InvoiceLine[]
}

model InvoiceLine {
  id        Int @id @default(autoincrement())
  invoiceId Int

  rowDescription String
  quantity       Float
  price          Float

  vat VAT

  lineTotalExcl Float
  vatAmount     Float
  lineTotalIncl Float

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

//debiteuren en crediteuren
model Relation {
  id        Int @id @default(autoincrement())
  companyId Int

  companyName   String
  contactPerson String?
  type          RelationType

  kvkNumber   String?
  btwNumber   String?
  IBAN        String?
  paymentTerm Int

  email       String
  phonenumber String?

  address  String?
  postcode String?
  city     String?
  country  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  invoices Invoice[]
}

enum VAT {
  VAT_0  @map("0")
  VAT_9  @map("9%")
  VAT_21 @map("21%")
}

enum RelationType {
  DEBTOR   @map("debitor")
  CREDITOR @map("creditor")
}

enum InvoiceStatus {
  //draft, open, payed, due
  DRAFT @map("draft")
  OPEN  @map("open")
  PAYED @map("payed")
  DUE   @map("due")
}
