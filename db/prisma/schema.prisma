generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         Int       @id @default(autoincrement())
  username   String
  password   String
  email      String    @unique
  role       String
  created_at DateTime  @default(now())
  updated_at DateTime?

  salesInvoices    SalesInvoice[]    @relation("CreatedSalesInvoices")
  purchaseInvoices PurchaseInvoice[] @relation("CreatedPurchaseInvoices")
  userCompanies    UserCompany[]
  ledgers          Ledger[]
}

model Company {
  id        Int     @id @default(autoincrement())
  name      String
  kvkNumber String?
  btwNumber String?
  address   String
  postcode  String
  city      String
  country   String
  iban      String?
  phone     String?
  email     String?
  website   String?
  logo      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            UserCompany[]
  debtors          Debtor[]
  creditors        Creditor[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
}

model UserCompany {
  id        Int @id @default(autoincrement())
  userId    Int
  companyId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model SalesInvoice {
  id            Int    @id @default(autoincrement())
  invoiceNumber String @unique

  companyId   Int
  debtorId    Int
  createdById Int

  title String

  invoiceDate DateTime
  dueDate     DateTime
  paymentTerm Int

  subTotal Decimal
  vatTotal Decimal
  total    Decimal

  status InvoiceStatus @default(DRAFT)

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation("CreatedSalesInvoices", fields: [createdById], references: [id])
  debtor    Debtor  @relation(fields: [debtorId], references: [id])

  invoiceLines SalesInvoiceLine[]
  transactions Transaction[]
}

model SalesInvoiceLine {
  id        Int @id @default(autoincrement())
  invoiceId Int

  rowDescription String
  quantity       Float
  price          Float

  vat VAT

  lineTotalExcl Float
  vatAmount     Float
  lineTotalIncl Float

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PurchaseInvoice {
  id            Int    @id @default(autoincrement())
  invoiceNumber String @unique

  companyId   Int
  creditorId  Int
  createdById Int

  title String

  invoiceDate DateTime
  dueDate     DateTime
  paymentTerm Int

  subTotal Decimal
  vatTotal Decimal
  total    Decimal

  paymentType PaymentType
  payedDate   DateTime?

  status InvoiceStatus @default(DRAFT)

  company   Company  @relation(fields: [companyId], references: [id])
  createdBy User     @relation("CreatedPurchaseInvoices", fields: [createdById], references: [id])
  creditor  Creditor @relation(fields: [creditorId], references: [id])

  invoiceLines PurchaseInvoiceLine[]
  transactions Transaction[]
}

model PurchaseInvoiceLine {
  id        Int @id @default(autoincrement())
  invoiceId Int

  rowDescription String
  quantity       Float
  price          Float

  vat VAT

  lineTotalExcl Float
  vatAmount     Float
  lineTotalIncl Float

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Debtor {
  id        Int @id @default(autoincrement())
  companyId Int

  companyName   String
  contactPerson String?

  kvkNumber   String?
  btwNumber   String?
  IBAN        String?
  paymentTerm Int

  email       String
  phonenumber String?

  address  String?
  postcode String?
  city     String?
  country  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  salesInvoices SalesInvoice[]
}

model Creditor {
  id        Int @id @default(autoincrement())
  companyId Int

  companyName   String
  contactPerson String?

  kvkNumber   String?
  btwNumber   String?
  IBAN        String?
  paymentTerm Int

  email       String
  phonenumber String?

  address  String?
  postcode String?
  city     String?
  country  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  purchaseInvoices PurchaseInvoice[]
}

model Ledger {
  id         Int     @id @default(autoincrement())
  number     Int
  name       String
  type       String
  category   String
  systemMade Boolean

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  lines transactionLine[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  reference   String
  amount      Decimal
  type        String //negative or positive amount

  salesInvoiceId Int?
  salesInvoice   SalesInvoice? @relation(fields: [salesInvoiceId], references: [id])

  purchaseInvoiceId Int?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])

  lines transactionLine[]
}

model transactionLine {
  id Int @id @default(autoincrement())

  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  ledgerId Int
  ledger   Ledger @relation(fields: [ledgerId], references: [id])

  type   String
  amount Decimal
}

enum VAT {
  VAT_0  @map("0")
  VAT_9  @map("9%")
  VAT_21 @map("21%")
}

enum InvoiceStatus {
  //draft, open, payed, due
  DRAFT @map("draft")
  OPEN  @map("open")
  PAYED @map("payed")
  DUE   @map("due")
}

enum PaymentType {
  IDEAL
  BANK_TRANSFER
  CREDIT_CARD
  DIRECT_DEBIT
  CASH
  PAYPAL
  CHEQUE
  OTHER
}
