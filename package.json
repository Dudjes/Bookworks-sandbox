{
  "name": "accounting-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "desktop",
    "server",
    "shared",
    "db"
  ],
  "scripts": {
    "start": "npm run dev",
    "postinstall": "npm run rebuild:electron-native",
    "dev": "npm run db:generate && concurrently -k \"npm:dev:server\" \"npm:dev:desktop\"",
    "dev:desktop": "npm --prefix desktop run dev",
    "dev:server": "npm --prefix server run dev",
    "db:generate": "npm --prefix db run prisma:generate",
    "db:push": "npm --prefix db run prisma:push",
    "db:migrate": "npm --prefix db run prisma:migrate",
    "db:studio": "npm --prefix db run prisma:studio",
    "rebuild:electron-native": "electron-rebuild -f -w better-sqlite3 -v 28.3.3",
    "electron:dev": "npm --prefix desktop run dev",
    "build": "npm --prefix shared run build && npm --prefix server run build && npm --prefix desktop run build",
    "preview": "npm --prefix desktop run preview"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1"
  }
}
